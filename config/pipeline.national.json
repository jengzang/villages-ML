{
  "dataset": {
    "key": "national",
    "db_path": "data/villages_national.db",
    "schema": "national"
  },
  "run": {
    "run_id_prefix": "national"
  },
  "retention": {
    "enabled": true,
    "drop_tables": [
      "全国自然村_预处理",
      "village_ngrams",
      "village_semantic_structure",
      "village_features",
      "village_spatial_features",
      "village_cluster_assignments"
    ]
  },
  "region_levels": ["city", "county"],
  "phases": {
    "0": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "prefix_min_length": 2,
        "prefix_confidence_threshold": 0.8,
        "metadata_version": "national_phase0_preprocessing"
      }
    },
    "1": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "vector_size": 80,
        "window": 3,
        "min_count": 5,
        "epochs": 10,
        "model_type": "skipgram",
        "workers": 4,
        "negative": 5,
        "output_dir": "models/embeddings_national",
        "precompute_similarities": true,
        "top_k": 20,
        "notes": "National conservative character embeddings"
      }
    },
    "2": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "output_dir": "results_national",
        "log_level": "INFO",
        "region_levels": [1, 2],
        "chunk_size": 50000,
        "persist_batch_size": 50000,
        "min_global_support": 100,
        "min_regional_support": 10,
        "smoothing_alpha": 1.0
      }
    },
    "3": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "lexicon_path": "data/semantic_lexicon_national_v1.json",
        "region_levels": [1, 2]
      }
    },
    "4": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "coordinate_bounds": "china",
        "eps_km": 5.0,
        "min_samples": 100,
        "method": "dbscan",
        "multi_resolution": true,
        "multi_resolution_configs": "national_eps_5:dbscan:5.0:100;national_hdbscan:hdbscan:0.0:80",
        "tendency_chars": 50
      }
    },
    "5": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "lexicon_path": "data/semantic_lexicon_national_v1.json",
        "batch_size": 50000
      }
    },
    "6": {
      "args": {
        "db_path": "data/villages_national.db",
        "region_level": 2,
        "k_range": [8, 12, 16, 20],
        "top_n_suffix2": 50,
        "top_n_suffix3": 30,
        "pca_components": 40,
        "n_init": 10,
        "max_iter": 300,
        "random_state": 42,
        "semantic_lexicon_path": "data/semantic_lexicon_national_v1.json",
        "use_semantic": true,
        "use_morphology": true,
        "use_diversity": true
      }
    },
    "7": {
      "args": {
        "db_path": "data/villages_national.db"
      }
    },
    "10": {
      "args": {
        "db_path": "data/villages_national.db",
        "significance_level": 0.01
      }
    },
    "11": {
      "args": {
        "db_path": "data/villages_national.db",
        "tables": "query_policy"
      }
    },
    "12": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "n_values": [2],
        "region_levels": [1, 2],
        "positions": ["all", "suffix"],
        "min_regional_count_by_n": "2:20",
        "min_global_count_by_n": "2:200",
        "skip_village_ngrams": true
      }
    },
    "13": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "mode": "hotspots",
        "hotspot_bandwidth_km": 12.0,
        "hotspot_threshold_percentile": 90.0,
        "hotspot_cluster_eps_km": 3.0,
        "hotspot_cluster_min_samples": 25,
        "hotspot_sample_size": 200000,
        "hotspot_full_count_radius_km": 5.0,
        "hotspot_sample_seed": 20260712,
        "batch_size": 50000
      }
    },
    "14": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "lexicon_path": "data/semantic_lexicon_national_v4.json",
        "basic_lexicon_path": "data/semantic_lexicon_national_v1.json",
        "detailed_lexicon_path": "data/semantic_lexicon_national_v4.json",
        "conflict_threshold": 20,
        "structure_progress_interval": 50000,
        "region_levels": [1, 2],
        "skip_village_structures": true
      }
    },
    "15": {
      "args": {
        "db_path": "data/villages_national.db",
        "region_levels": [1, 2],
        "top_k_global": 150,
        "z_score_threshold": 2.5,
        "summary_limit": 10
      }
    },
    "16": {
      "args": {
        "db_path": "data/villages_national.db"
      }
    },
    "17": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "lexicon_path": "data/semantic_lexicon_national_v4.json"
      }
    },
    "18": {
      "args": {
        "db_path": "data/villages_national.db",
        "schema": "national",
        "output_dir": "results_national/morphology",
        "suffix_lengths": "2",
        "prefix_lengths": "",
        "region_levels": [1, 2],
        "chunk_size": 50000,
        "persist_batch_size": 50000,
        "min_global_support": 100,
        "min_regional_support": 10,
        "smoothing_alpha": 1.0
      }
    }
  }
}
